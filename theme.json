{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,

	"settings": {
		"color": {
			"background": false,
			"button": false,
			"caption": false,
			"custom": false,
			"customDuotone": false,
			"customGradient": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"duotone": [],
			"gradients": [],
			"heading": false,
			"link": false,
			"palette": [
				{ "slug": "kcdw-midnight", "color": "#0B272C", "name": "Midnight" },
				{ "slug": "kcdw-forest",   "color": "#225656", "name": "Forest" },
				{ "slug": "kcdw-teal",     "color": "#6BC0AE", "name": "Teal" },
				{ "slug": "kcdw-steel",    "color": "#5D8294", "name": "Steel" },
				{ "slug": "kcdw-sienna",   "color": "#855523", "name": "Sienna" },
				{ "slug": "kcdw-mist",     "color": "#CCD2D1", "name": "Mist" },
				{ "slug": "kcdw-body",     "color": "#3D3D3D", "name": "Body" },
				{ "slug": "kcdw-white",    "color": "#ffffff", "name": "White" }
			],
			"text": false
		},
		"typography": {
			"customFontSize": false,
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": false,
			"fontFamilies": [
				{
					"name": "Barlow Condensed",
					"slug": "barlow-condensed",
					"fontFamily": "\"Barlow Condensed\", sans-serif"
				},
				{
					"name": "Barlow",
					"slug": "barlow",
					"fontFamily": "Barlow, sans-serif"
				},
				{
					"name": "IBM Plex Mono",
					"slug": "ibm-plex-mono",
					"fontFamily": "\"IBM Plex Mono\", monospace"
				}
			],
			"fontSizes": [
				{ "name": "Small",  "slug": "small",  "size": "0.875rem" },
				{ "name": "Normal", "slug": "normal", "size": "1rem" },
				{ "name": "Large",  "slug": "large",  "size": "1.25rem" },
				{ "name": "H3",     "slug": "h3",     "size": "1.75rem" },
				{ "name": "H2",     "slug": "h2",     "size": "2.375rem" },
				{ "name": "H1",     "slug": "h1",     "size": "3.25rem" }
			],
			"fontStyle": false,
			"fontWeight": false,
			"letterSpacing": false,
			"lineHeight": false,
			"textAlign": false,
			"textColumns": false,
			"textDecoration": false,
			"textTransform": false
		},
		"custom": {}
	},

	"styles": {
		"color": {
			"background": "var(--wp--preset--color--kcdw-white)",
			"text": "var(--wp--preset--color--kcdw-body)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--barlow)",
			"fontSize": "1rem",
			"lineHeight": "1.7"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
					"fontSize": "3.25rem",
					"fontWeight": "900",
					"textTransform": "uppercase"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
					"fontSize": "2.375rem",
					"fontWeight": "900",
					"textTransform": "uppercase"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
					"fontSize": "1.75rem",
					"fontWeight": "900"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
					"fontWeight": "900"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
					"fontWeight": "900"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow-condensed)",
					"fontWeight": "900"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--kcdw-teal)"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--kcdw-sienna)",
					"text": "var(--wp--preset--color--kcdw-white)"
				},
				"border": {
					"radius": "3px"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--barlow)",
					"fontWeight": "600"
				}
			}
		}
	},

	"customTemplates": [
		{ "name": "template-action", "title": "Take Action Sub-Page", "postTypes": ["page"] },
		{ "name": "template-donate", "title": "Donate",               "postTypes": ["page"] }
	]
}
